{
  "name": "serial-debug-tool",
  "version": "1.0.0",
  "description": "Serial Debug Tool - Desktop Edition",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist-portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.serialdebug.tool",
    "productName": "Serial Debug Tool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "Serial Debug.html",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": null
    },
    "portable": {
      "artifactName": "SerialDebug_Portable.exe"
    }
  }
}
